heatmapAnnotation <- function(j, i, x, y, w, h, fill) {
    value <- abs(t(as.matrix(heatmap_matrix))[i, j])
    
    if (value > 3) {
        grid::grid.text("****", x, y, rot=90)
    } else if (value > 2) {
        grid::grid.text("***", x, y, rot=90)
    } else if (value > 1.3) {
        grid::grid.text("**", x, y, rot=90)
    } else if (value > 1) {
        grid::grid.text("*", x, y, rot=90)
    }
}

